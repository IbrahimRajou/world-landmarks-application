<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detailsAct"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailsActivity"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <ImageButton
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/back_image"
            android:id="@+id/backButton"
            android:layout_marginTop="50dp"
            android:layout_marginStart="35dp"
            android:scaleType="fitXY"
            android:background="#ffffff"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/noName"
                android:id="@+id/itemName"
                android:textStyle="bold"
                android:textSize="24sp"
                android:layout_marginStart="30dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <ImageButton
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:src="@drawable/star_image"
                android:id="@+id/starButton"
                android:layout_marginEnd="30dp"
                android:scaleType="fitXY"
                android:background="#ffffff"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageButton
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/previous_image"
                android:id="@+id/previousButton"
                android:scaleType="fitXY"
                android:background="#ffffff"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="8dp"
                />
            <ImageView
                android:layout_width="300dp"
                android:layout_height="250dp"
                android:background="@drawable/edit_text_design"
                android:id="@+id/detailsImage"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:scaleType="fitXY"
                />
            <ImageButton
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/next_image"
                android:id="@+id/nextButton"
                android:scaleType="fitXY"
                android:background="#ffffff"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="5dp"
                />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_label"
                android:textColor="#0009FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="15dp" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/noLocation"
                android:id="@+id/itemLocation"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginEnd="20dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description_label"
                android:textColor="#0009FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="15dp"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description1"
                android:id="@+id/description1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="19sp"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description2"
                android:id="@+id/description2"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="19sp"
                android:layout_marginBottom="10dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/description3"
                android:id="@+id/description3"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="19sp"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>